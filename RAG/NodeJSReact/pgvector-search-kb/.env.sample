DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=vectordb

# AI_PROVIDER: azure | litellm | mock (default) — mock uses random normalized vectors (no API calls)
AI_PROVIDER=azure

# Azure OpenAI Configs (used when AI_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT="https://<your_resource_name>.openai.azure.com/"
AZURE_OPENAI_API_KEY="<your_api_key>"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME="<your_deployment_name_of_embedding_ai_model>"
AZURE_OPENAI_API_VERSION="2023-05-15"

# Lite LLM Configs (used when AI_PROVIDER=litellm)
LITELLM_BASE_URL="https://<your_litellm_server_url>/v1"
LITELLM_API_KEY="<your_api_key>"
LITELLM_EMBEDDING_MODEL="text-embedding-3-small"
LITELLM_TIMEOUT_SEC=20
LITELLM_MAX_TOKENS=500
LITELLM_TEMPERATURE=0.1

#text-embedding-3-large
#EMBEDDING_DIMENSIONS=3072
#text-embedding-ada-002 or text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
