PORT=3002

# Folder with demo-knowledge-base.json + demo-datasets.json (optional; defaults to ./data next to server).
# DEMO_DATA_DIR=

# Data-tab bundled JSON dataset key (`demo-datasets.json` top-level key). Override via request `itemDbTbl` / `item_db_tbl` or DOM `item-db-tbl`.
# Example second sheet: ITEM_DB_TABLE=hotels ITEM_DB_COL_ID=hotel_id
ITEM_DB_TABLE=items
ITEM_DB_COL_ID=item_id

# AI_PROVIDER: azure (default) | litellm | mock
AI_PROVIDER=azure

# Azure OpenAI Configs
OPENAI_ENDPOINT="https://<your_resource>.openai.azure.com/"
OPENAI_API_KEY="<your-openai-key>"
OPENAI_DEPLOYMENT_NAME="<your-deployment-name>"
OPENAI_MODEL_NAME="text-embedding-3-small"
OPENAI_API_VERSION="2023-05-15"
OPENAI_CHAT_ENDPOINT="https://<your_resource>.openai.azure.com/"
OPENAI_CHAT_API_KEY="<your-openai-key>"
OPENAI_CHAT_DEPLOYMENT_NAME="<your-deployment-name>"
OPENAI_CHAT_MODEL_NAME="gpt-5.4-mini"
OPENAI_CHAT_API_VERSION="2023-05-15"

# Lite LLM Configs (used when AI_PROVIDER=litellm)
# LITELLM_BASE_URL: OpenAI-compatible base, WITH /v1 suffix (e.g. https://your-proxy.example.com/v1).
# LITELLM_CHAT_MODEL / LITELLM_EMBEDDING_MODEL: MUST match model ids your proxy exposes. If chat returns
#   400 "Invalid model name", call: GET {LITELLM_BASE_URL}/models with the same API key and pick an id from the list.
LITELLM_BASE_URL="https://<your_litellm_server_url>/v1"
LITELLM_API_KEY="<your_api_key>"
LITELLM_CHAT_MODEL="<model_id_from_/v1/models>"
LITELLM_EMBEDDING_MODEL="text-embedding-3-small"
LITELLM_TIMEOUT_SEC=20
# Output cap for chat completions. 500 often cuts off mid-sentence or mid-citation (e.g. "[Source"). Use 2048+ for markdown + inline sources.
LITELLM_MAX_TOKENS=2048
LITELLM_TEMPERATURE=1

#text-embedding-3-large
#EMBEDDING_DIMENSIONS=3072
#text-embedding-ada-002 or text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Optional TTS (`POST /v1/audio/speech` OpenAI-compatible: LiteLLM, OpenAI, etc.). Empty TTS_* reuses LiteLLM base URL + key when AI_PROVIDER=litellm.
# TTS_BASE_URL=https://api.openai.com/v1
# TTS_API_KEY=<optional override if different from chat>
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_RESPONSE_FORMAT=mp3
TTS_TIMEOUT_SEC=45
TTS_MAX_CHARS=4096

# Echo upstream TTS failures in `/api/tts` JSON responses (avoid in production).
# TTS_ERROR_DETAIL=1

# Optional public URL for export links (defaults to request Host).
# PUBLIC_BASE_URL=https://your-api.example.com

# Data tab: append "### Suggested / possible solutions" (KB RAG + general guidance). Default on (1). Set 0 to skip extra embed + chat.
CHAT_DATA_MODE_SUGGESTION=1