PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=vectordb

# AI_PROVIDER: azure (default) | litellm | mock
AI_PROVIDER=azure

# Azure OpenAI Configs
OPENAI_ENDPOINT="https://<your_resource>.openai.azure.com/"
OPENAI_API_KEY="<your-openai-key>"
OPENAI_DEPLOYMENT_NAME="<your-deployment-name>"
OPENAI_MODEL_NAME="text-embedding-3-small"
OPENAI_API_VERSION="2023-05-15"
OPENAI_CHAT_ENDPOINT="https://<your_resource>.openai.azure.com/"
OPENAI_CHAT_API_KEY="<your-openai-key>"
OPENAI_CHAT_DEPLOYMENT_NAME="<your-deployment-name>"
OPENAI_CHAT_MODEL_NAME="gpt-5.4-mini"
OPENAI_CHAT_API_VERSION="2023-05-15"

# Lite LLM Configs (used when AI_PROVIDER=litellm)
LITELLM_BASE_URL="https://<your_litellm_server_url>/v1"
LITELLM_API_KEY="<your_api_key>"
LITELLM_CHAT_MODEL="gpt-5.4-2026-03-05"
LITELLM_EMBEDDING_MODEL="text-embedding-3-small"
LITELLM_TIMEOUT_SEC=20
LITELLM_MAX_TOKENS=500
LITELLM_TEMPERATURE=1

#text-embedding-3-large
#EMBEDDING_DIMENSIONS=3072
#text-embedding-ada-002 or text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
